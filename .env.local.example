# ─── AI API Keys ───
# Agrega tu API Key para activar IA real en JAB
# Se usa en este orden: Groq → OpenAI → Gemini

# Groq (más rápida, gratis con límite)
# NUNCA usar NEXT_PUBLIC_ — las API keys deben ser solo server-side
GROQ_API_KEY=gsk_tu-key-aqui

# OpenAI (ChatGPT/GPT-4)
# OPENAI_API_KEY=sk-proj-xxxxx

# Google Gemini
# GEMINI_API_KEY=xxxxx

# Auth secret for JWT tokens (cambia esto en producción)
AUTH_SECRET=tu-secreto-seguro-aqui-cambiar-en-produccion

# Firebase database URL
FIREBASE_DB_URL=https://system-control-administrative-default-rtdb.firebaseio.com
