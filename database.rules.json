{
  "rules": {
    ".read": false,
    ".write": false,
    "usuarios-it": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('usuarios-it').child(auth.uid).child('rol').val() === 'admin'",
      "$uid": {
        ".validate": "newData.hasChildren(['codigo', 'username', 'rol', 'activo'])",
        "pin": { ".validate": false }
      }
    },
